# =============================================================================
# WellNest Environment Configuration
#
# Copy this to .env and fill in real values.  Never commit .env itself.
# =============================================================================

# --- Postgres (used by dbt, dagster, soda, and the API) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wellnest
POSTGRES_USER=wellnest
POSTGRES_PASSWORD=changeme

# connection string assembled from the above — some libs want this format
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Dagster ---
DAGSTER_HOME=/path/to/orchestration
DAGSTER_PG_HOST=${POSTGRES_HOST}
DAGSTER_PG_PORT=${POSTGRES_PORT}
DAGSTER_PG_DB=dagster
DAGSTER_PG_USER=${POSTGRES_USER}
DAGSTER_PG_PASSWORD=${POSTGRES_PASSWORD}

# --- dbt ---
DBT_PROFILES_DIR=./transformation
DBT_TARGET=dev

# --- OpenAI (for the RAG / community Q&A features) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- MLflow tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=wellnest-default

# --- Chicago Data Portal (Socrata) ---
# free tier is fine — 1000 req/hr with an app token
SOCRATA_APP_TOKEN=your-socrata-app-token
SOCRATA_DOMAIN=data.cityofchicago.org

# --- CDC PLACES API ---
# no auth needed but we set a user-agent so they don't throttle us
CDC_PLACES_BASE_URL=https://data.cdc.gov/resource
CDC_USER_AGENT=WellNest/0.1 (health-equity-research)

# --- Census Bureau ---
CENSUS_API_KEY=your-census-api-key
CENSUS_YEAR=2023

# --- API settings ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Streamlit dashboard ---
STREAMLIT_PORT=8501
STREAMLIT_THEME=light

# --- Report generation ---
REPORTS_OUTPUT_DIR=./reports/output
REPORTS_LOGO_PATH=./docs/assets/logo.png

# --- Misc ---
LOG_LEVEL=INFO
ENVIRONMENT=development
