{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wellnest/ingestion/census_acs",
  "title": "Census ACS 5-Year Tract-Level Estimates",
  "description": "Demographic and socioeconomic data from the American Community Survey. The Census API returns -666666666 for missing/suppressed values -- we replace these with null during ingestion. Max 50 variables per API call.",
  "type": "object",
  "required": ["state_fips", "county_fips", "tract_fips", "full_fips"],
  "properties": {
    "state_fips": {
      "type": "string",
      "pattern": "^[0-9]{2}$"
    },
    "county_fips": {
      "type": "string",
      "pattern": "^[0-9]{3}$"
    },
    "tract_fips": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "full_fips": {
      "type": "string",
      "pattern": "^[0-9]{11}$",
      "description": "Concatenated state + county + tract FIPS"
    },
    "total_population": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "poverty_universe": {
      "type": ["number", "null"],
      "description": "Population for whom poverty status is determined"
    },
    "poverty_below_total": {
      "type": ["number", "null"]
    },
    "poverty_rate": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "median_hh_income": {
      "type": ["integer", "null"]
    },
    "uninsured_children": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Sum of uninsured under 6 and 6-18, male and female"
    },
    "insurance_universe": {
      "type": ["number", "null"]
    },
    "edu_universe": {
      "type": ["number", "null"]
    },
    "pct_bachelors_plus": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "race_universe": {
      "type": ["number", "null"]
    },
    "race_white_alone": {
      "type": ["number", "null"]
    },
    "race_black_alone": {
      "type": ["number", "null"]
    },
    "race_hispanic": {
      "type": ["number", "null"]
    }
  },
  "additionalProperties": true
}
