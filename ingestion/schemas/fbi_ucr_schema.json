{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wellnest/ingestion/fbi_ucr",
  "title": "FBI UCR County Crime Data",
  "description": "County-level crime statistics from the FBI Crime Data Explorer. The NIBRS transition in 2021 caused a big drop in reporting coverage, so 2019-2020 data is more reliable for national analysis. Crime counts are estimated (imputed) for non-reporting agencies.",
  "type": "object",
  "required": ["state_fips", "county_fips", "year"],
  "properties": {
    "state_fips": {
      "type": "string",
      "pattern": "^[0-9]{2}$"
    },
    "county_fips": {
      "type": "string",
      "pattern": "^[0-9]{5}$"
    },
    "state_name": {
      "type": ["string", "null"]
    },
    "county_name": {
      "type": ["string", "null"]
    },
    "year": {
      "type": "integer"
    },
    "population": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "FBI population figure, may differ slightly from ACS"
    },
    "violent_crime": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Total: murder + rape + robbery + aggravated assault"
    },
    "murder": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "rape": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "robbery": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "aggravated_assault": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "property_crime": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Total: burglary + larceny + motor vehicle theft"
    },
    "burglary": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "larceny": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "motor_vehicle_theft": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "violent_crime_rate": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Per 100,000 population"
    },
    "property_crime_rate": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Per 100,000 population"
    }
  },
  "additionalProperties": true
}
