{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wellnest/ingestion/cdc_places",
  "title": "CDC PLACES Health Indicators",
  "description": "Model-based health estimates at county and census tract level from CDC PLACES. County names frequently have trailing whitespace -- cleaned during ingestion.",
  "type": "object",
  "required": ["stateabbr", "locationname", "measure"],
  "properties": {
    "year": {
      "type": ["integer", "null"]
    },
    "stateabbr": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "statedesc": {
      "type": ["string", "null"]
    },
    "locationname": {
      "type": "string",
      "description": "County or tract name. Watch for trailing whitespace."
    },
    "locationid": {
      "type": ["string", "null"],
      "description": "FIPS code for counties (5-digit), tract code for tracts (11-digit)"
    },
    "data_value": {
      "type": ["number", "null"],
      "description": "The point estimate (percentage, rate, etc.)"
    },
    "data_value_unit": {
      "type": ["string", "null"]
    },
    "data_value_type": {
      "type": ["string", "null"],
      "description": "Age-adjusted or crude prevalence"
    },
    "low_confidence_limit": {
      "type": ["number", "null"]
    },
    "high_confidence_limit": {
      "type": ["number", "null"]
    },
    "measure": {
      "type": "string",
      "description": "Human-readable measure name (e.g., 'Current asthma')"
    },
    "measureid": {
      "type": ["string", "null"]
    },
    "category": {
      "type": ["string", "null"]
    },
    "categoryid": {
      "type": ["string", "null"]
    },
    "totalpopulation": {
      "type": ["integer", "null"]
    },
    "geolocation": {
      "type": ["string", "null"],
      "description": "Point geometry as text (lat, lon)"
    }
  },
  "additionalProperties": true
}
