{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wellnest/ingestion/hrsa_mua",
  "title": "HRSA Medically Underserved Areas/Populations",
  "description": "MUA/MUP designations from HRSA. IMU score <= 62 qualifies as medically underserved. Governor-designated MUPs can have IMU > 62 -- we keep these but flag them.",
  "type": "object",
  "required": ["mua_source_id", "state_abbr", "designation_type"],
  "properties": {
    "mua_source_id": {
      "type": "string"
    },
    "mua_name": {
      "type": ["string", "null"]
    },
    "state_abbr": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "state_fips": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{2}$"
    },
    "county_fips": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{5}$"
    },
    "designation_type": {
      "type": "string",
      "enum": ["MUA", "MUP"]
    },
    "imu_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "Index of Medical Underservice, 0-100. Lower = worse."
    },
    "status": {
      "type": ["string", "null"]
    },
    "designation_date": {
      "type": ["string", "null"]
    },
    "rural_status": {
      "type": ["string", "null"],
      "description": "Only populated for about 70% of records"
    },
    "medically_underserved": {
      "type": "boolean",
      "description": "True if IMU <= 62 or IMU is null"
    }
  },
  "additionalProperties": true
}
