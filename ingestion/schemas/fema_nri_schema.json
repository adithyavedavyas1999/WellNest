{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wellnest/ingestion/fema_nri",
  "title": "FEMA National Risk Index",
  "description": "County-level composite risk scores for 18 natural hazards. The CSV has a UTF-8 BOM and some columns contain footnote markers (asterisks) in numeric fields. About 50 counties are missing risk scores.",
  "type": "object",
  "required": ["state_fips", "county_fips", "county_name", "state_name"],
  "properties": {
    "state_fips": {
      "type": "string",
      "pattern": "^[0-9]{2}$"
    },
    "county_fips": {
      "type": "string",
      "pattern": "^[0-9]{5}$"
    },
    "county_name": {
      "type": "string"
    },
    "state_name": {
      "type": "string"
    },
    "risk_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "Overall risk score, 0-100"
    },
    "risk_rating": {
      "type": ["string", "null"],
      "enum": ["Very Low", "Relatively Low", "Relatively Moderate", "Relatively High", "Very High", null]
    },
    "eal_score": {
      "type": ["number", "null"],
      "description": "Expected annual loss score (0-100)"
    },
    "eal_value": {
      "type": ["number", "null"],
      "description": "Expected annual loss in dollars"
    },
    "sovi_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "Social vulnerability score. Used in our Safety pillar."
    },
    "sovi_rating": {
      "type": ["string", "null"]
    },
    "resl_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "Community resilience score"
    },
    "resl_rating": {
      "type": ["string", "null"]
    },
    "population": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "building_value": {
      "type": ["number", "null"],
      "minimum": 0
    }
  },
  "additionalProperties": true
}
